import "p2"
import "math"

// Zero-allocation: Fixed-size arrays reside statically in Hub RAM.
var sineLut [4096]uint16

func main() {
    var pinX int = 26
    var pinY int = 20
    var freqX float32 = 150.0
    var freqY float32 = 200.0
    var phaseOffsetDeg float32 = 90.0
    var sampleRateHz float32 = 100000.0

    // Pre-calculate the Sine Wave Lookup Table.
    // Notice the strict 'for' loop syntax: OctoGo omits init/post statements
    // to keep the LL(1) grammar and runtime simple.
    var i int = 0
    for i < 4096 {
        var angle float32 = (float32(i) / 4096.0) * 2.0 * 3.14159265
        sineLut[i] = uint16((math.Sin(angle) + 1.0) * 32767.5)
        i = i + 1
    }

    // Configure Smart Pins using the p2 zero-overhead abstractions
    var dacMode int = p2.PDac124R3V | p2.POe | p2.PDacDitherRnd
    
    p2.WritePinMode(pinX, dacMode)
    p2.WritePinX(pinX, 1)
    p2.PinDirHigh(pinX)

    p2.WritePinMode(pinY, dacMode)
    p2.WritePinX(pinY, 1)
    p2.PinDirHigh(pinY)

    // Set up DDS variables with the phase offset
    var phaseAccX uint32 = 0
    var phaseAccY uint32 = uint32((phaseOffsetDeg / 360.0) * 4294967296.0)

    var phaseStepX uint32 = uint32((freqX / sampleRateHz) * 4294967296.0)
    var phaseStepY uint32 = uint32((freqY / sampleRateHz) * 4294967296.0)

    var cyclesPerSample int = p2.ClockFreq() / 100000

    // The high-speed DDS generation loop. 
    // An absent condition in OctoGo evaluates to 'true' for infinite loops.
    for {
        // Shift accumulators to get the 12-bit LUT index
        var indexX uint32 = phaseAccX >> 20
        var indexY uint32 = phaseAccY >> 20

        // Push the voltage to the pins via the wypin wrapper
        p2.WritePinY(pinX, sineLut[indexX])
        p2.WritePinY(pinY, sineLut[indexY])

        // Advance phases
        phaseAccX = phaseAccX + phaseStepX
        phaseAccY = phaseAccY + phaseStepY

        // Yield to hardware clock
        p2.WaitX(cyclesPerSample)
    }
}
