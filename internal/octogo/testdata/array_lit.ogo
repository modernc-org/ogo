// COMPILE

// An array literal "[N]T{...}" and a slice literal "[]T{...}" give their elements
// positionally. An array literal may supply fewer values than its length, zeroing
// the rest; a slice literal's length is however many it supplies.

type P struct {
	x int
	y int
}

func sum(s []int) int {
	t := 0
	for _, v := range s {
		t += v
	}
	return t
}

func use() {
	// Inferred and declared, array and slice.
	tab := [4]int{10, 20, 30, 40}
	part := [4]int{1, 2}
	var typed [3]int = [3]int{7, 8, 9}
	xs := []int{5, 6, 7}
	var ts []int = []int{1, 1}
	empty := []int{}

	// Element types other than int, and a nested struct literal.
	strs := [2]string{"a", "b"}
	pts := [2]P{P{1, 2}, P{3, 4}}
	flags := [2]bool{true, false}

	println(tab[3], part[1], part[3], typed[2], len(tab))
	println(xs[2], len(xs), cap(xs), sum(xs), ts[1], len(empty))
	println(strs[1], pts[1].x, flags[0])
}
