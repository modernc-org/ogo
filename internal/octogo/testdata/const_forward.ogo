// COMPILE

// Regression: constants are evaluated on demand, so a constant may reference
// one declared later in source (a forward reference) and still be fully
// evaluated. "first" resolves to 42 -- usable where a constant is required,
// such as an array bound (which would report an error were it left unknown).

const width = 16
const area = width * width

const first = second
const second = 42

var buf [first]int
