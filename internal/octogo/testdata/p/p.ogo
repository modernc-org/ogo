const p = 'p'

// Use is an exported, referenceable member so that importers can satisfy the
// unused-import check.
func Use() {}

// Do is an exported function, the callee of the package-qualified call
// "p.Do()" exercised by call_base.ogo.
func Do() {}

// Value is an exported variable, the target of the package-qualified read
// "p.Value" exercised by read_base.ogo.
var Value int

// T is an exported type, named in the qualified type position "p.T" exercised by
// qualified_type.ogo. It carries an exported field F and an unexported field g,
// plus an exported and an unexported method, so cross_pkg_access.ogo can check that
// an importer reaches only the exported members.
type T struct {
	F int
	g int
}

func (r T) Get() int { return r.F }

func (r T) hidden() int { return r.g }

// t is an unexported type, referenced by qualified_type.ogo to check that the
// export rule applies to a qualified type name too.
type t struct{ f int }
