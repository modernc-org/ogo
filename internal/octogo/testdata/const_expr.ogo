// Regression: constant comparisons and parenthesized constant expressions must
// fold without crashing the checker, including as array bounds.

const lo = 3
const hi = 10

const inRange = lo < hi
const eq = (2 + 3) == 5
const nested = ((1 + 2) * 3) > (4 + 5)

const size = (2 + 2) * 4
var buf [size]int
var flags [(1 + 1)]bool
