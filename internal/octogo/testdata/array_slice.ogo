// COMPILE

// A slice is a { pointer, length, capacity } view over a fixed array's storage --
// no copy, so writing through the slice mutates the array. []T is a value passed by
// value; xs[i], len(xs) and cap(xs) read through the header. Slicing a[low:high]
// sets cap = len(a) - low, and re-slicing may extend the length back up to cap
// (never acquiring new memory -- the P2 has no heap). A slice variable needs an
// explicit []T type for now: short-declaring one (s := a[1:3]) is not yet inferred.

func fill(xs []int) {
	i := 0
	for i < len(xs) {
		xs[i] = i * i
		i++
	}
}

func sum(xs []int) int {
	total := 0
	i := 0
	for i < len(xs) {
		total = total + xs[i]
		i++
	}
	return total
}

func main() {
	var a [8]int
	fill(a[:]) // writes back into a: a[i] == i*i

	var s []int
	s = a[2:5] // len 3, cap 6 (== len(a) - 2)
	println(len(s))
	println(cap(s))
	println(sum(s))

	s = s[:6] // extend within cap: len 6, cap 6
	println(len(s))
	println(sum(s))

	println(cap(a)) // an array's cap is its length, 8
}
