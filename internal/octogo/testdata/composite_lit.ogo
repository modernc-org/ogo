// COMPILE

// A composite literal "T{a, b}" builds a value of the named struct type from its
// fields, positionally, in declaration order. "T{}" supplies none and zeroes them
// all. Fields declared together ("x, y int") count once per name.
//
// The fields may instead be given by name, "T{b: 2}", in any order and in any
// number: a field the literal does not name takes its zero value. The two forms
// may not be mixed, since once one element names its field, position stops meaning
// anything.

type Q struct {
	v int
}

type P struct {
	q Q
	n int
	s string
}

type Pair struct {
	x, y int
}

func take(p P) int {
	return p.n
}

func make2() P {
	return P{Q{1}, 2, "made"}
}

func use() {
	// Every position an expression may occupy, other than a control-flow header.
	a := P{Q{1}, 2, "hi"}
	var b P = P{}
	b = P{Q{3}, 4, "set"}
	c := Pair{5, 6}
	n := 7
	d := Pair{n * 2, n + 1}
	println(take(P{Q{8}, 9, "arg"}), make2().n)
	println(a.q.v, b.n, c.x, c.y, d.x, d.y)

	// Parenthesizing lets a literal be used where a header would otherwise take
	// the brace as its block.
	e := (Pair{10, 11})
	if e.x > 0 {
		println(e.x, e.y)
	}
}

func keyed() {
	// Any subset of the fields, in any order; the rest are zeroed.
	a := P{n: 1}
	b := P{s: "hi", q: Q{2}}
	c := P{q: Q{3}, n: 4, s: "all"}
	d := Pair{y: 5}
	e := Pair{x: 6, y: 7}

	// A keyed element's value is an ordinary expression, and may be a literal of
	// either form itself.
	n := 8
	g := P{n: n * 2, q: Q{v: n}}

	println(take(P{n: 9}), a.n, b.q.v, b.s)
	println(c.n, c.s, d.x, d.y, e.x, g.q.v)
}

var pkgKeyed = P{n: 10, s: "pkg"}

func usePkgKeyed() {
	println(pkgKeyed.n, pkgKeyed.s, pkgKeyed.q.v)
}
