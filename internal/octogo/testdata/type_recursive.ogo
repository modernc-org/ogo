// COMPILE

// Regression: a type may reference any other type in its body -- itself
// (linked lists, trees), a type declared later (forward reference), or another
// type that references it back (mutual reference) -- resolved by the two-pass
// type checker (names first, bodies second).

type Node struct {
	val  int
	next *Node
}

type Tree struct {
	value int
	left  *Tree
	right *Tree
}

type List struct {
	items []List
}

// Forward and mutual references: Edge names Vertex before it is declared, and
// Vertex names Edge back.
type Edge struct {
	to *Vertex
}

type Vertex struct {
	edges []Edge
}
